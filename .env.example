# Supabase — copie este arquivo para .env.local e preencha os valores reais
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_KEY=sua_anon_key_aqui

# Basic Auth (usado pelo Vercel Edge Middleware — NÃO adicionar prefixo VITE_)
# Estas variáveis são configuradas diretamente no painel do Vercel, não no .env.local
AUTH_USER=admin
AUTH_PASSWORD=senha_segura_aqui
